# Copy this file to local/.env and fill in the values below.
# After editing: chmod 600 local/.env  (see README "Setting up Telegram").

# Bot token returned by @BotFather after running /newbot in Telegram.
TELEGRAM_BOT_TOKEN=

# Your chat ID — obtain by starting a chat with the bot, sending it any message,
# then GET https://api.telegram.org/bot<TOKEN>/getUpdates and reading
# result[0].message.chat.id from the JSON response.
TELEGRAM_CHAT_ID=
